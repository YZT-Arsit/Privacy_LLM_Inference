{
  "config": {
    "batch_size": 2,
    "prompt_len": 8,
    "max_new_tokens": 8,
    "vocab_size": 128,
    "hidden_size": 64,
    "num_layers": 2,
    "num_heads": 4,
    "ffn_dim": 256,
