  "logits_metrics": {
    "max_abs_error": 5.587935447692871e-06,
    "relative_l2_error": 1.0959353858197574e-05,
    "allclose": true
  },
  "stage3_scope": {
    "prefill_decode": true,
    "kv_cache": true,
    "greedy_generation": true,
    "sampling": false,
    "huggingface": false,
    "modelscope": false,
    "real_tee": false
  }
